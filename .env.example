# Puerto API
PORT=3001

# Dialecto para desarrollo local rapido
# DB_DIALECT=sqlite
# DB_STORAGE=./habitos.sqlite

# Conexion PostgreSQL (opcion 1: URL completa)
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/habitos_db
# Conexion PostgreSQL (opcion 2: campos separados)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=habitos_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# CORS (separado por coma). Vacio = permitir todos.
CORS_ORIGINS=http://localhost:5173
